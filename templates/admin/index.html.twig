<style>
    .row {
        margin: 0;
    }

    ._none {
        display: none;
    }

    ._block {
        display: block;
    }

    .header {
        height: 80px;
        background-color: #c5e0e0;
        position: fixed;
        width: 100%;
    }

    .bars {
        width: 90px;
        height: 80px;
    }

    .bars:hover {
        cursor: pointer;
        background-color: rgba(188, 209, 209, 0.2);
    }

    .bars i {
        font-size: 30px;
        margin-top: 25px;
    }

    .margin-dive-content {
        transition: 0.4s;
        margin-left: 300px;
    }

    .sidebar { 
        height: 100%; 
        position: fixed;
        background-color: #055e4d;
        margin: 0;
    }

    .inside {
        transition: 0.4s;
        width: 300px;
    }

    .outside {
        width: 0;
        padding: 0;
        transition: 0.4s;
    }

    .logo img {
        height: 80px;
    }

    .profile {
        padding: 10px;
    }

    ._form .form-group {
        margin: 20px 0;
    }

    .check-toggle-password:checked {
        background-color: green;
    }

    .camera {
        position: absolute;
        margin-left: 43px;
        margin-top: 38px;
    }

    .rotate {
        -moz-transition: all 0.2s linear;
        -webkit-transition: all 0.2s linear;
        transition: all 0.2s linear;
    }

    .rotate.arrow-up {
        -ms-transform: rotate(-180deg);
        -moz-transform: rotate(-180deg);
        -webkit-transform: rotate(-180deg);
        transform: rotate(-180deg);
    }

    .dive-drop-down {
        width: auto;
        position: fixed;
        background-color: #c5e0e0;
        right: 11%;
        border-radius: 0 0 5px 5px;
    }

    .dive-drop-down ul {
        margin: 0;
        padding: 0;
    }

    .dive-drop-down li {
        list-style-type: none;
        color: #02472c;
        font-size: 20px;
        padding: 5px 30px;
    }

    .dive-drop-down li:hover {
        background-color: #e1f2eb;
        cursor: pointer;
    }

    .dive-drop-down a {
        text-decoration: none;
    }

    .btn-licence {
        background-color: #0a6b58;
        color: white;
    }

    .btn-licence:hover {
        color: white;
        background-color: #108f77;
    }

    .add-licence {
        height: 50px;
        padding: 0 20px;
        font-size: 20px;
        float: right;
    }

    .dive-table {
        width:  100%;
        overflow-x: auto;
    }

    .table {
        width: 3000px;
    }
</style>

