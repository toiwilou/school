<script>
    //https://htmldom.dev/drag-to-scroll/
    var diveDropDown = document.querySelector('.dive-drop-down');
    var nameProfile = document.querySelector('.name-profile');
    var bars = document.querySelector('.bars');
    var sidebar = document.querySelector('.sidebar');
    var diveContentRight = document.querySelector('.dive-content-right');
    var dive = document.querySelector('#ma-dive');
    var rotateProfile = document.querySelector('.rotate-profile');
    var checkTogglePassword = document.querySelector('.check-toggle-password');
    var modalDivePassword = document.querySelector('.modal-dive-password');

    checkTogglePassword.addEventListener('click', function(){
        if(checkTogglePassword.checked){
            modalDivePassword.style.display = 'block';
        } else {
            modalDivePassword.style.display = 'none';
        }
    });

    window.addEventListener('click', function(e){   
        if (nameProfile.contains(e.target)){
            if(diveDropDown.classList.contains('_none')){
                diveDropDown.classList.remove('_none');
                diveDropDown.classList.add('_block');
                rotateProfile.classList.add('arrow-up');
            } else {
                diveDropDown.classList.remove('_block');
                diveDropDown.classList.add('_none');
                rotateProfile.classList.remove('arrow-up');
            }
        } else{
            diveDropDown.classList.remove('_block');
            diveDropDown.classList.add('_none');
            rotateProfile.classList.remove('arrow-up');
        }

        if (bars.contains(e.target)){
            if(sidebar.classList.contains('outside')){
                sidebar.classList.remove('outside');
                sidebar.classList.add('inside');
                diveContentRight.style.marginLeft = '300px';
                diveContentRight.style.transition = '0.4s';
            } else {
                sidebar.classList.remove('inside');
                sidebar.classList.add('outside');
                diveContentRight.style.marginLeft = '0';
                diveContentRight.style.transition = '0.4s';
            }
        } else if (!sidebar.contains(e.target)) {
            sidebar.classList.remove('inside');
            sidebar.classList.add('outside');
            diveContentRight.style.marginLeft = '0';
            diveContentRight.style.transition = '0.4s';
        }
    });
</script>

